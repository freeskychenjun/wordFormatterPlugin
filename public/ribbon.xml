<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui" onLoad="ribbon.OnAddinLoad" loadImage="ribbon.LoadImage">
  <ribbon startFromScratch="false">
    <tabs>
      <tab id="formatTab" label="文档排版" insertBeforeMso="TabHome">
        <group id="formatGroup" label="排版工具">
          <button id="openTaskPane"
                  label="排版助手"
                  size="large"
                  image="assistant"
                  onAction="ribbon.OnAction"
                  getEnabled="ribbon.OnGetEnabled"
                  getVisible="ribbon.OnGetVisible"
                  getImage="ribbon.GetImage"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
